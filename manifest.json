---
layout: null
---
{
  "name": "{{ site.title | escape }}",
  "short_name": "{{ site.title | escape }}",
  "description": "{{ site.description | strip_html | strip_newlines | escape }}",
  "start_url": "{{ site.baseurl }}/",
  "display": "standalone",
  "background_color": "#eff6ff",
  "theme_color": "#3b82f6",
  "icons": [
    {
      "src": "{{ site.baseurl }}/{{ site.favicon_path }}",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "{{ site.baseurl }}/assets/gitbook/images/apple-touch-icon-precomposed-152.png",
      "sizes": "152x152",
      "type": "image/png"
    }
  ]
}
